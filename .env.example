# ============================================================================
# INTERNSHIP AGENT DEV - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and fill in your actual credentials
# This tool generates professional marketing videos using AI agents
# ============================================================================

# ============================================================================
# CORE VIDEO SETTINGS
# ============================================================================
# Video dimensions (default: 1080x1920 for vertical 9:16 aspect ratio)
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_ASPECT_RATIO=9:16

# Image generation aspect ratio (defaults to VIDEO_ASPECT_RATIO if not set)
IMAGE_ASPECT_RATIO=9:16

# ============================================================================
# LM STUDIO - LOCAL LLM (RECOMMENDED FOR PRIVACY)
# ============================================================================
# LM Studio provides local inference without external API calls
# Download from: https://lmstudio.ai
# 
# After starting LM Studio:
# 1. Load a model (e.g., Mistral 7B, Llama 2)
# 2. Start the local server (default: http://localhost:1234)
# 3. Set LM_STUDIO_ENABLED=true to use it

LLM_PROVIDER=lmstudio
LM_STUDIO_ENABLED=true
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=auto
LM_STUDIO_AUTO_DETECT=true

# ============================================================================
# GEMINI API - FALLBACK LLM (REQUIRED IF LM_STUDIO NOT AVAILABLE)
# ============================================================================
# Get your API key from: https://ai.google.dev/
# Costs: Free tier available with usage limits
# 
# Models available:
# - gemini-2.5-flash (recommended, fast and cheap)
# - gemini-1.5-pro (more capable, slower)
# - gemini-1.5-flash (balanced)

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp

# ============================================================================
# APIFY - META ADS SCRAPING
# ============================================================================
# Apify automatically scrapes successful Meta ads
# Get your token from: https://apify.com/
# 
# Actor: apify/meta-ads-dataset or whoareyouanas/meta-ad-scraper
# Returns: Successful ads data with creative copy, imagery, and engagement metrics

APIFY_API_TOKEN=your_apify_token_here
APIFY_META_ADS_ACTOR_ID=whoareyouanas/meta-ad-scraper
APIFY_META_ADS_COUNTRY=US
APIFY_META_ADS_SEARCH_QUERY=trading
APIFY_META_ADS_MAX_AGE_DAYS=30

# ============================================================================
# GOOGLE DRIVE/DOCS - SOURCE MATERIAL EXTRACTION
# ============================================================================
# Allows extracting text from Google Docs for use as source material
# Get credentials from: https://console.cloud.google.com/
# 
# How to set up:
# 1. Create a Google Cloud project
# 2. Enable Google Drive API and Google Docs API
# 3. Create a service account
# 4. Download the service account JSON key
# 5. Share your Google Doc with the service account email
# 6. Set GOOGLE_APPLICATION_CREDENTIALS to the JSON file path

GOOGLE_APPLICATION_CREDENTIALS=./cred.json
GOOGLE_DRIVE_FILE_ID=your_google_doc_id_here
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.readonly

# ============================================================================
# TEXT-TO-SPEECH (TTS) - AUDIO GENERATION
# ============================================================================
# Primary: ElevenLabs API (premium, natural voices)
# Fallback: Edge TTS (free, Microsoft, good quality)
#
# ElevenLabs API: Get key from: https://elevenlabs.io/
# Costs: Free tier (10k characters/month), paid plans available

TTS_PROVIDER=elevenlabs
TTS_FALLBACK=edge-tts

# Edge TTS: No API key needed, built-in to system
# Voice examples: en-US-AriaNeural, en-US-GuyNeural, en-GB-RyanNeural
EDGE_TTS_VOICE=en-US-AriaNeural
EDGE_TTS_LANGUAGE=en-US
EDGE_TTS_OUTPUT_FORMAT=audio-24khz-48kbitrate-mono-mp3

# ElevenLabs Settings
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ============================================================================
# IMAGE GENERATION - POLLINATIONS.AI FALLBACK
# ============================================================================
# Primary: Gemini API
# Fallback: Pollinations.ai (free, no auth needed)
# 
# If Gemini API key is not set, the tool automatically falls back to 
# Pollinations.ai for image generation

GEMINI_IMAGE_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-exp:generateContent

# ============================================================================
# LOGGING AND OUTPUT
# ============================================================================
# Log file location (created automatically)
RUN_LOG_FILE=./output/run.log

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# REMOTION VIDEO RENDERING
# ============================================================================
# Remotion app directory (usually: ./remotion-app)
REMOTION_APP_DIR=./remotion-app

# Entry point for Remotion (usually: src/index.tsx)
REMOTION_ENTRY_POINT=src/index.tsx

# Composition ID (usually: Video)
REMOTION_COMPOSITION_ID=Video

# Output directory within Remotion app
RENDER_OUTPUT_DIR=out

# ============================================================================
# OPTIONAL: ADVANCED SCENE TIMING
# ============================================================================
# Minimum duration each scene should appear (seconds)
SCENE_MIN_DURATION_SECONDS=3

# Gap between scenes (seconds)
SCENE_GAP_SECONDS=0.5

# ============================================================================
# NOTES
# ============================================================================
# 1. For local-only setup: Configure only LM_STUDIO (no API keys needed)
# 2. For cloud setup: Get GEMINI_API_KEY and APIFY_TOKEN
# 3. For advanced: Set up Google Drive integration
# 4. Edge TTS works without setup (uses Microsoft's free service)
# 5. Check ./docs/ for detailed guides on each service
